# WAGO WebVisu Adapter Configuration

# Server Ports
PORT=8080
MCP_PORT=3002

# Browser Mode (set to false for debugging with visible browser)
HEADLESS=true

# Protocol debug/session trace
PROTOCOL_DEBUG_HTTP=false
PROTOCOL_SESSION_TRACE=true
PROTOCOL_SESSION_TRACE_DIR=./data/protocol-trace
PROTOCOL_LOG_RAW_FRAME_DATA=false
