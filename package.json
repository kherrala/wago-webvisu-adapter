{
  "name": "wago-webvisu-adapter",
  "version": "1.0.0",
  "description": "HTTP API adapter for WAGO WebVisu home automation portal",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test:connection": "ts-node src/test-connection.ts",
    "test:acceptance": "ts-node src/test-acceptance.ts",
    "calibrate": "ts-node src/calibrate.ts",
    "fetch:plc-certs": "ts-node src/utils/download-plc-certs.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jpeg-js": "^0.4.4",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.3",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^20.10.0",
    "@types/pngjs": "^6.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
